{
  "functions": {
    "api/scan-chart.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/dhan-sync",
      "schedule": "30 10 * * 1-5"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
